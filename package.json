{
  "name": "dogtag-webui",
  "version": "0.1.0",
  "homepage": ".",
  "private": true,
  "author": "",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/http-proxy": "^11.4.4",
    "@fastify/static": "^9.1.3",
    "@patternfly/patternfly": "^6.4.0",
    "@patternfly/react-core": "^6.4.0",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-table": "^6.4.0",
    "@reduxjs/toolkit": "^2.6.1",
    "fastify": "^5.8.5",
    "ldapts": "^8.1.7",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.12.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --import tsx server/index.ts",
    "build": "tsc -b && vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=server/dist/index.mjs --packages=external",
    "start:server": "node server/dist/index.mjs",
    "lint": "eslint --color --max-warnings 0",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.8",
    "@eslint/js": "^9.24.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.18.1",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.1.1",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "@vitest/coverage-v8": "^3.2.3",
    "esbuild": "^0.28.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.40.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.3"
  },
  "engines": {
    "node": ">=18"
  }
}
