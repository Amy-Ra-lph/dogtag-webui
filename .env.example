# Dogtag CA backend URL
VITE_CA_TARGET_URL=https://localhost:8443

# --- Vite Dev Server (frontend-only mode) ---
# Client certificate for legacy dev proxy (direct to CA, without Fastify backend)
VITE_CA_CERT_PATH=certs/agent.cert
VITE_CA_KEY_PATH=certs/agent.key

# Dev server bind address (use 0.0.0.0 to expose on network)
VITE_DEV_HOST=localhost

# Point Vite proxy to the Fastify backend instead of direct to CA
# (set this when running `npm run dev:server` alongside `npm run dev`)
# VITE_BACKEND_URL=http://localhost:3000

# --- Vite Auth Middleware (dev only, demo mode) ---
# LDAP authentication (omit VITE_LDAP_URL to use demo backend)
# VITE_LDAP_URL=ldap://localhost:389
# VITE_LDAP_BASE_DN=o=pki-tomcat-CA
# VITE_LDAP_BIND_DN=cn=Directory Manager
# VITE_LDAP_BIND_PASSWORD=
# VITE_LDAP_USER_SEARCH_BASE=ou=people,o=pki-tomcat-CA
# VITE_LDAP_GROUP_SEARCH_BASE=ou=groups,o=pki-tomcat-CA
# VITE_LDAP_TLS_REJECT_UNAUTHORIZED=true
# VITE_LDAP_TLS_CA_CERT=/path/to/ds-ca.crt
# VITE_LDAP_STARTTLS=false

# --- Fastify Backend (production / container) ---
# These env vars are used by the Fastify backend (server/app.ts)
# and the container entrypoint. No VITE_ prefix.

# CA_TARGET_URL=https://ca.example.com:8443
# REKOR_URL=http://rekor.example.com:3000
# BACKEND_PORT=3000

# TLS validation for backend-to-CA connection (default: false for PoC)
# CA_TLS_REJECT_UNAUTHORIZED=true
# CA_BUNDLE=/path/to/ca-chain.pem
# (or use NODE_EXTRA_CA_CERTS=/path/to/ca-chain.pem)

# Client CA cert for nginx mTLS verification (optional)
# CLIENT_CA_CERT=/etc/nginx/certs/client-ca.pem

# LDAP fallback auth (used if Dogtag basic auth fails)
# LDAP_URL=ldaps://ds.example.com:636
# LDAP_BASE_DN=o=pki-tomcat-CA
# LDAP_BIND_DN=cn=Directory Manager
# LDAP_BIND_PASSWORD=
# LDAP_TLS_REJECT_UNAUTHORIZED=true
# LDAP_TLS_CA_CERT=/path/to/ds-ca.crt
# LDAP_STARTTLS=false
